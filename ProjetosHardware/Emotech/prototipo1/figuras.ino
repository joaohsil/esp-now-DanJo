void setup() {
  Serial.begin(115200);
  
  //Verifica se o display foi conectado corretamente
  if(!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) {
    Serial.println("Falha no SSD1306");
    for(;;);
  }
  
  //Limpa display 
  display.clearDisplay();

  //Declara o que o display vai instanciar
  // mude a variavel "burguer" para as outras para testar as imagens
  display.drawBitmap(0, 0, burguer, 128, 64, WHITE);
  
  //Chama a imagem e deixa ela estática
  display.display();
  
  Serial.println("Imagem exibida no display!");
}

